    "date-fns": "^4.4.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "0.45.2",
    "framer-motion": "^12.42.2",
    "html-to-image": "^1.11.13",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
